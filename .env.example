DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here

# Turso (production) — get these from turso.tech after creating a database
TURSO_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Local dev only — leave TURSO_URL/TOKEN unset and this file is used instead
# GUILD_ID is only needed if you want guild-specific (instant) command registration
GUILD_ID=your_server_id_here
